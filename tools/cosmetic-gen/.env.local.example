# Gymbros generation pipeline — LOCAL ONLY. Never commit the real file.
# Copy to .env.local and fill in. These secrets stay on the dev machine; the app never sees them.

# Gemini (Nanobanan Pro / Nano Banana). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Image model id. Nano Banana Pro = gemini-3-pro-image-preview; Nano Banana = gemini-2.5-flash-image.
# Override if Google renames the model.
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Supabase — SERVICE ROLE key (bypasses RLS; writes generated_images / prompt_versions / avatar_renders + uploads to storage).
# Get it from Supabase dashboard > Project Settings > API. NOT the anon key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket the app reads avatar/cosmetic art from.
SUPABASE_AVATARS_BUCKET=avatars
